{
  "heartbeat": {
    "enabled": true,
    "interval_minutes": 60,
    "tasks": [
      {
        "id": "verify-all",
        "command": "python scripts/verify_all.py . --url http://localhost:3000 --no-e2e",
        "interval_hours": 4,
        "description": "Run standard verification suite"
      },
      {
        "id": "distill-patterns",
        "command": "python scripts/reasoning_bank.py distill",
        "interval_hours": 24,
        "description": "Consolidate reasoning bank patterns"
      },
      {
        "id": "security-scan",
        "command": "python scripts/verify_all.py . --url http://localhost:3000 --no-e2e",
        "interval_hours": 12,
        "description": "Deeper security check"
      },
      {
        "id": "exchange-sync",
        "command": "python scripts/exchange.py sync",
        "interval_hours": 1,
        "description": "Sync with remote registry for updates"
      }
    ],
    "logging": {
      "path": ".Agentica/logs/heartbeat.log",
      "level": "INFO"
    }
  }
}
